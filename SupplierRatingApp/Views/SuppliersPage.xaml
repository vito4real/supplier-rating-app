<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="SupplierRatingApp.Views.SuppliersPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Поставщики">

    <Grid RowDefinitions="Auto,Auto,Auto,*" Padding="20" RowSpacing="16">

        <VerticalStackLayout Grid.Row="0" Spacing="6">
            <Label
                Text="Поставщики"
                FontSize="28"
                FontAttributes="Bold" />
        </VerticalStackLayout>

        <Entry
            Grid.Row="1"
            Placeholder="Поиск поставщика..."
            Text="{Binding SearchText}" 
            ClearButtonVisibility="WhileEditing" />

        <HorizontalStackLayout Grid.Row="2" Spacing="12">
            <Button
                Text="Добавить поставщика"
                Clicked="AddSupplierButton_Clicked" />

            <Button
                Text="Обновить"
                Clicked="RefreshButton_Clicked" />
        </HorizontalStackLayout>

        <CollectionView
            Grid.Row="3"
            x:Name="SuppliersCollectionView"
            ItemsSource="{Binding Suppliers}"
            SelectionMode="Single"
            SelectionChanged="SuppliersCollectionView_SelectionChanged">

            <CollectionView.EmptyView>
                <Label
                    Text="Ничего не найдено"
                    HorizontalOptions="Center"
                    VerticalOptions="Center" />
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <VerticalStackLayout Margin="0,0,0,10">
                        <Frame
                            Padding="12"
                            BorderColor="#DDDDDD"
                            CornerRadius="8">
                            <VerticalStackLayout Spacing="6">
                                <Label
                                    Text="{Binding Name}"
                                    FontSize="18"
                                    FontAttributes="Bold" />

                                <Label
                                    Text="{Binding Notes}"
                                    FontSize="14"
                                    Opacity="0.7" />

                                <Label
                                    Text="{Binding LastRatingText, StringFormat='Рейтинг: {0}'}" />

                                <Label
                                    Text="{Binding CategoryText, StringFormat='Категория: {0}'}" />

                                <Label
                                    Text="{Binding LastCheckDateText, StringFormat='Последняя оценка: {0}'}"
                                    FontSize="13"
                                    Opacity="0.7" />
                            </VerticalStackLayout>
                        </Frame>
                    </VerticalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>

        </CollectionView>
    </Grid>
</ContentPage>